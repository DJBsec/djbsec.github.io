<div class="djb-card djb-card--accent-left mb-5">
  <div class="d-flex justify-content-between align-items-start mb-3">
    <div>
      <p class="eyebrow" style="margin-bottom: 4px;">{{ include.category.eyebrow }}</p>
      <h3 class="djb-card__title" style="margin-bottom: 4px;">{{ include.category.title }}</h3>
      <p class="djb-card__desc">{{ include.category.description }}</p>
    </div>
    <a href="{{ include.category.repo_url }}" class="btn-djb-secondary" style="white-space: nowrap; font-size: var(--text-xs);" target="_blank" rel="noopener noreferrer">Browse Folder</a>
  </div>
  <div>
    <div class="table-responsive">
      <table class="table table-hover page-token-table mb-0">
        <thead>
          <tr>
            <th style="width: 25%;">Prompt File</th>
            <th style="width: 60%;">Description</th>
            <th style="width: 15%;">Link</th>
          </tr>
        </thead>
        <tbody>
          {% for prompt in include.category.prompts %}
            <tr>
              <td><strong>{{ prompt.name }}</strong></td>
              <td>{{ prompt.description }}</td>
              <td><a href="{{ prompt.url }}" class="btn btn-sm btn-djb-secondary" target="_blank" rel="noopener noreferrer">View</a></td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% if include.category.footer_html %}
      <p style="font-size: var(--text-sm); color: var(--color-ink-muted); margin-top: 12px; margin-bottom: 0;">
        {{ include.category.footer_html }}
      </p>
    {% endif %}
  </div>
</div>
